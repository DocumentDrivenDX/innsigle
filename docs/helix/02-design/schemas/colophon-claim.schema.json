{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://innsigle.dev/schema/colophon-claim/v1.json",
  "title": "Innsigle colophon claim payload v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["innsigle", "type", "issued_at", "issuer", "subjects", "colophon"],
  "properties": {
    "innsigle": { "const": "1" },
    "type": { "const": "https://innsigle.dev/claim/colophon/v1" },
    "issued_at": { "type": "string", "minLength": 1 },
    "issuer": {
      "type": "object",
      "required": ["id", "name", "key_id", "key_url"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "key_id": { "type": "string", "pattern": "^ed25519:[0-9a-f]{32}$" },
        "key_url": {
          "type": "string",
          "minLength": 8,
          "description": "Absolute issuer document URL (ADR-003); covered by claim signature"
        }
      }
    },
    "subjects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["digest"],
        "properties": {
          "uri": { "type": "string" },
          "digest": {
            "type": "object",
            "required": ["alg", "value"],
            "properties": {
              "alg": { "const": "sha256" },
              "value": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
            }
          }
        }
      }
    },
    "colophon": {
      "type": "object",
      "required": ["schema_version", "composition", "ingredients"],
      "properties": {
        "schema_version": { "const": "1" },
        "composition": {
          "enum": ["human-authored", "mixed", "model-primary"]
        },
        "ingredients": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["kind", "name"],
            "properties": {
              "kind": { "enum": ["model", "tool", "human", "other"] },
              "name": { "type": "string", "minLength": 1 },
              "role": { "type": "string" },
              "version": { "type": ["string", "null"] },
              "uri": { "type": "string" }
            }
          }
        },
        "notes": { "type": ["string", "null"] }
      }
    }
  }
}
